# Supabase (required for production/Vercel deployment)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Optional: legacy Express backend (local dev only)
REACT_APP_API_URL=http://localhost:5000

# Optional: force mock mode when no backend is available
REACT_APP_MOCK_MODE=false

# Google Maps (optional, for map features)
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
